{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenteval-forge.local/schemas/evoforge_external_evaluation_schema_v0.1.json",
  "title": "AgentEval Forge -> EvoForge External Evaluation (v0.1)",
  "description": "AgentEval Forge's own copy of the report contract consumed by EvoForge's attach-agenteval command. Mirrors EvoForge schema version 0.1. The two repositories stay independent; this file documents the contract on the producer side and is enforced in code by agenteval/integrations/evoforge/contract.py.",
  "type": "object",
  "required": [
    "evaluation_schema_version",
    "source_system",
    "source_evaluation_id",
    "evaluated_at",
    "evaluator",
    "subject",
    "verdict",
    "scores",
    "checks",
    "rejection_reasons",
    "warnings",
    "requires_human_review"
  ],
  "properties": {
    "evaluation_schema_version": { "type": "string", "const": "0.1" },
    "source_system": { "type": "string", "const": "AgentEval Forge" },
    "source_evaluation_id": { "type": "string", "minLength": 1 },
    "evaluated_at": { "type": "string", "minLength": 1 },
    "evaluator": {
      "type": "object",
      "required": ["name", "version", "policy_version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "policy_version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "subject": {
      "type": "object",
      "required": ["evoforge_run_id", "trace_id", "artifact_hashes"],
      "properties": {
        "evoforge_run_id": { "type": "string", "minLength": 1 },
        "trace_id": { "type": "string", "minLength": 1 },
        "artifact_hashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        }
      },
      "additionalProperties": true
    },
    "verdict": { "type": "string", "enum": ["pass", "fail", "needs_review"] },
    "scores": {
      "type": "object",
      "required": [
        "correctness",
        "safety",
        "minimality",
        "evidence_quality",
        "overall"
      ],
      "properties": {
        "correctness": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "safety": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "minimality": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "evidence_quality": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "overall": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "message"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "warning", "unknown"]
          },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "rejection_reasons": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "requires_human_review": { "type": "boolean" }
  },
  "additionalProperties": true
}
